# Copy this file to .env.local and fill in your keys.
# .env.local is gitignored so your keys never get committed.
#
# Used by the Vercel serverless function at /api/ai.
# When running `npm run dev` locally, the serverless function lives in api/ai.js;
# Vite does not proxy to it by default — see README for the two ways to test AI
# locally (Vercel CLI `vercel dev` vs. running the UI against a deployed backend).
ANTHROPIC_API_KEY=sk-ant-...

# Supabase config for cross-device sync + accounts.
# The publishable key (formerly "anon key") is safe to ship to the browser
# because Row Level Security policies restrict every query to the user's own
# data. Find these at Project Settings → API Keys (publishable) and
# Project Settings → Data API (URL) in the Supabase dashboard.
# Add the same two vars to Vercel → Settings → Environment Variables for prod.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
