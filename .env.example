# Copy this file to .env.local and fill in your key.
# .env.local is gitignored so your key never gets committed.
#
# Used by the Vercel serverless function at /api/ai.
# When running `npm run dev` locally, the serverless function lives in api/ai.js;
# Vite does not proxy to it by default — see README for the two ways to test AI
# locally (Vercel CLI `vercel dev` vs. running the UI against a deployed backend).
ANTHROPIC_API_KEY=sk-ant-...
